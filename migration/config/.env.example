# Zkopíruj na  migration/config/.env  a vyplň. .env je v .gitignore (necommitovat).

# --- WooCommerce (zdroj dat) ---
# URL e-shopu bez koncového lomítka.
WOO_URL=https://www.budman-shop.cz
# REST API klíče: WooCommerce → Nastavení → Pokročilé → REST API (stačí oprávnění "Číst").
WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Shoptet (cíl) ---
# URL klonového/zkušebního e-shopu (bez koncového lomítka).
SHOPTET_BASE_URL=https://budman-klon.myshoptet.com

# --- Volby převodu ---
# Měna a DPH (musí být nastaveno v Shoptetu PŘED importem).
CURRENCY=CZK
DEFAULT_VAT_RATE=21
# Ceny ve feedu jsou s DPH? 1 = ano (typické pro CZ B2C), 0 = bez DPH.
PRICES_INCLUDE_VAT=1

# Struktura URL kategorií na Shoptetu pro redirecty:
#   none   => cíl je /<slug>/            (kategorie bez prefixu)
#   prefix => cíl je /kategorie/<slug>/  (kategorie s prefixem)
SHOPTET_CATEGORY_URL_MODE=none

# Woo prefixy URL (jak vypadají STARÉ odkazy) – upravit dle reálného nastavení permalinků.
WOO_PRODUCT_PREFIX=/produkt
WOO_CATEGORY_PREFIX=/kategorie-produktu
